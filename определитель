#include <stdio.h>
#include <math.h>

float determinant(int n, float matrix[n][n]) {
    float det = 1.0;

    for (int i = 0; i < n; i++) {
        int max = i;
        for (int k = i + 1; k < n; k++) {
            if (fabsf(matrix[k][i]) > fabsf(matrix[max][i])) {
                max = k;
            }
        }

        if (fabsf(matrix[max][i]) < 1e-6) {
            return 0;
        }

        if (max != i) {
            for (int j = 0; j < n; j++) {
                float temp = matrix[i][j];
                matrix[i][j] = matrix[max][j];
                matrix[max][j] = temp;
            }
            det = -det;
        }

        for (int j = i + 1; j < n; j++) {
            float factor = matrix[j][i] / matrix[i][i];
            for (int k = i; k < n; k++) {
                matrix[j][k] -= factor * matrix[i][k];
            }
        }
        det *= matrix[i][i];
    }
    return det;
}

int main() {
    int n;

    scanf("%d", &n);

    float matrix[n][n];

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%f", &matrix[i][j]);
        }
    }

    float det = determinant(n, matrix);
    printf("%f\n", det);

    return 0;
}
